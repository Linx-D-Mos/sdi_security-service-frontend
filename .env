# URL de tu API Laravel (Normalmente Laravel sail o serve usan 8000 o el host principal)
VITE_API_URL=http://127.0.0.1

# Credenciales de WebSockets para Reverb (Sin interpolaciones tipo `${...}` porque Vite no las soporta por defecto)
VITE_REVERB_APP_KEY=cashcontrol_local_key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http